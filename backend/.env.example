# KisanSat Environment Variables
# Copy this file to .env and fill in your API keys

# Anthropic (Claude) - Required for Advisory Agent
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenWeatherMap - Weather data
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Agromonitoring - NDVI and soil data
AGROMONITORING_API_KEY=your_agromonitoring_api_key_here

# API Ninjas - Commodity prices
API_NINJAS_API_KEY=your_api_ninjas_api_key_here

# NASA Earthdata - Satellite imagery (optional)
NASA_EARTHDATA_TOKEN=your_nasa_earthdata_token_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
